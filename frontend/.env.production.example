# ==============================================================================
# frontend/.env.production.example — Frontend environment variables for Vercel
# ==============================================================================
# How to use:
#   Option A (recommended): Set in Vercel Dashboard → Project → Settings → Environment Variables
#   Option B: Create frontend/.env.production (gitignored) for local production testing
#
# NEVER commit .env.production with real values to git.
# ==============================================================================

# ── API URL ───────────────────────────────────────────────────────────────────
# Must be the HTTPS URL of your Render backend
# NEXT_PUBLIC_ prefix makes this available in browser-side code
NEXT_PUBLIC_API_URL=https://theknowledgeorbits-backend.onrender.com/api/v1

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Create a Sentry project → copy the DSN
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE@o0.ingest.sentry.io/0
SENTRY_ORG=REPLACE_WITH_SENTRY_ORG_SLUG
SENTRY_PROJECT=REPLACE_WITH_SENTRY_PROJECT_SLUG
# Create at: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=REPLACE_WITH_SENTRY_AUTH_TOKEN
