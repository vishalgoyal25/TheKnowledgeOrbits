# ==============================================================================
# .env.production.example — Backend environment variables for Render
# ==============================================================================
# Copy this file, fill in real values, and paste them into:
#   Render Dashboard → Your Service → Environment → Add Environment Variable
#
# NEVER commit real secrets to git. This file contains only placeholder values.
# ==============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=core.settings.prod
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY  # python -c "import secrets; print(secrets.token_urlsafe(64))"
DEBUG=False

# ── Allowed Hosts & Origins ───────────────────────────────────────────────────
# Your Render service subdomain (required from day 1)
ALLOWED_HOSTS=theknowledgeorbits-backend.onrender.com
# After connecting a custom domain, append it:
# ALLOWED_HOSTS=theknowledgeorbits-backend.onrender.com,api.yourdomain.com

# CSRF: HTTPS URLs of all trusted origins (backend + frontend)
CSRF_TRUSTED_ORIGINS=https://theknowledgeorbits-backend.onrender.com,https://theknowledgeorbits.vercel.app

# CORS: only the frontend origin(s)
CORS_ALLOWED_ORIGINS=https://theknowledgeorbits.vercel.app

# ── Supabase Database ─────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → Database → Connection info
# Use the "Connection pooling" host (port 5432) for PgBouncer (recommended for free tier)
DB_NAME=postgres
DB_USER=postgres.REPLACE_YOUR_PROJECT_REF
DB_PASSWORD=REPLACE_WITH_SUPABASE_DB_PASSWORD
DB_HOST=aws-0-ap-south-1.pooler.supabase.com  # YOUR region endpoint
DB_PORT=5432

# ── AI Services ───────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY
HF_API_TOKEN=hf_REPLACE_WITH_YOUR_HUGGINGFACE_TOKEN
USE_EMBEDDING_API=True   # Always True in cloud — no GPU, avoids loading 400MB model

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=REPLACE_WITH_BREVO_LOGIN_EMAIL
EMAIL_HOST_PASSWORD=REPLACE_WITH_BREVO_SMTP_KEY  # Different from your Brevo account password!
DEFAULT_FROM_EMAIL=REPLACE_WITH_YOUR_SENDER_EMAIL
BREVO_API_KEY=REPLACE_WITH_BREVO_API_KEY  # Optional — only if using Brevo API client

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=https://theknowledgeorbits.vercel.app

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=https://REPLACE@o0.ingest.sentry.io/0  # Leave empty to disable
SENTRY_ENVIRONMENT=production
