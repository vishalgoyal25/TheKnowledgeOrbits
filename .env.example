# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/TheKnowledgeOrbits
POSTGRES_DB=TheKnowledgeOrbits
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys
GROQ_API_KEY=your-groq-api-key-here
SENTRY_DSN=your-sentry-dsn-here

# Research Agent (AgenticAI engine) — LLM pool + tools + LLMOps
CEREBRAS_API_KEY=your-cerebras-api-key-here   # Verification/Reflection/Summary (cloud.cerebras.ai)
TAVILY_API_KEY=your-tavily-api-key-here       # primary web search (app.tavily.com)
EXA_API_KEY=your-exa-api-key-here             # fallback search (dashboard.exa.ai) — optional
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key     # LLMOps tracing (us.cloud.langfuse.com)
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://us.cloud.langfuse.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Email (for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
